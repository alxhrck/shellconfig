[color]
	ui = auto
[color "branch"]
	current = green
	local = yellow
	remote = yellow reverse
[color "diff"]
	meta = white bold
	frag = cyan bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[core]
	excludesfile = ~/.gitignore
